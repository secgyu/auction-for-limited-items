generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum AuctionStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products    Product[]
  bids        Bid[]
  wonAuctions Auction[] @relation("AuctionWinner")

  @@map("users")
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  images      String[]
  category    String
  condition   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller   User   @relation(fields: [sellerId], references: [id])
  sellerId String

  auction Auction?

  @@map("products")
}

model Auction {
  id           String        @id @default(uuid())
  startPrice   Int
  currentPrice Int
  bidIncrement Int           @default(1000)
  startTime    DateTime
  endTime      DateTime
  status       AuctionStatus @default(SCHEDULED)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  product   Product @relation(fields: [productId], references: [id])
  productId String  @unique

  winner   User?   @relation("AuctionWinner", fields: [winnerId], references: [id])
  winnerId String?

  bids Bid[]

  @@map("auctions")
}

model Bid {
  id        String   @id @default(uuid())
  amount    Int
  createdAt DateTime @default(now())

  auction   Auction @relation(fields: [auctionId], references: [id])
  auctionId String

  bidder   User   @relation(fields: [bidderId], references: [id])
  bidderId String

  @@map("bids")
}
